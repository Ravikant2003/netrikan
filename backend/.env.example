# Gemini (required)
GEMINI_API_KEY=your_gemini_api_key
NETRIKAN_GEMINI_MODEL=gemini-2.5-flash
NETRIKAN_LLM_TEMPERATURE=0.2

# Optional: agent debug logs
NETRIKAN_AGENT_VERBOSE=false

# Optional: model version folder (under backend/core/models/<version>)
NETRIKAN_MODEL_VERSION=

# Optional: disable external routing calls (OSRM)
NETRIKAN_NO_NETWORK=0

# Route context enrichment (optional)
NETRIKAN_ROUTE_CONTEXT=1

# OpenRouteService Directions (optional)
OPENROUTESERVICE_API_KEY=OPENROUTESERVICE_API_KEY_REMOVED=

# OpenStreetMap Overpass (optional)
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter

# Crime risk indexing (optional)
NETRIKAN_CRIME_H3_RES=8

# Threshold calibration (optional)
NETRIKAN_THRESHOLDS_PATH=

# Training data (optional)
NETRIKAN_TRAIN_DATA=
NETRIKAN_CALIBRATION_DATA=

# Firebase Cloud Messaging (optional)
# Path to service account JSON: export GOOGLE_APPLICATION_CREDENTIALS=/abs/path.json
FCM_PROJECT_ID=

# Notification integrations (optional)
# If unset, backend logs MOCK notifications.
NETRIKAN_PUSH_WEBHOOK_URL=
NETRIKAN_SMS_WEBHOOK_URL=
NETRIKAN_CALL_WEBHOOK_URL=
NETRIKAN_POLICE_WEBHOOK_URL=

# Force mock notifier even if webhook URLs are set
NETRIKAN_NOTIFIER_MOCK_ONLY=0

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional template support
TWILIO_WHATSAPP_TEMPLATE_SID=
TWILIO_WHATSAPP_TEMPLATE_VARS={"1":"12/1","2":"3pm"}
# Optional: route police alerts to your WhatsApp (demo mode)
TWILIO_WHATSAPP_POLICE_TO=

